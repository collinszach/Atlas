# ============================================================
# Atlas — Environment Variables
# Copy this file to .env and fill in each value.
# Never commit .env to git.
# ============================================================

# ------------------------------------------------------------
# Database (PostgreSQL + PostGIS)
# These are used by both docker-compose and the backend.
# Pick a strong password for POSTGRES_PASSWORD — it only needs
# to work inside the Docker network.
# ------------------------------------------------------------
POSTGRES_DB=atlas
POSTGRES_USER=atlas
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://atlas:changeme@atlas-db:5432/atlas
DATABASE_URL_SYNC=postgresql+psycopg2://atlas:changeme@atlas-db:5432/atlas

# ------------------------------------------------------------
# Redis
# No changes needed unless you move Redis off the default port.
# ------------------------------------------------------------
REDIS_URL=redis://atlas-redis:6379/0

# ------------------------------------------------------------
# Clerk (auth)
# Dashboard: https://dashboard.clerk.com → your app → API Keys
#   CLERK_SECRET_KEY          — "Secret keys" section (sk_live_...)
#   CLERK_WEBHOOK_SECRET      — Webhooks → your endpoint → Signing Secret
#   NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY — "Publishable key" (pk_live_...)
# ------------------------------------------------------------
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...

# ------------------------------------------------------------
# MinIO (photo storage)
# Change MINIO_ACCESS_KEY / MINIO_SECRET_KEY from the defaults.
# MINIO_PUBLIC_URL must be the public-facing URL that browsers
# use to load photos — set to your Cloudflare tunnel URL in prod.
# ------------------------------------------------------------
MINIO_ENDPOINT=atlas-minio:9000
MINIO_ACCESS_KEY=changeme
MINIO_SECRET_KEY=changeme_secret
MINIO_BUCKET_PHOTOS=atlas-photos
MINIO_LICENSE_KEY=
STORAGE_BACKEND=minio

# Local dev:
# MINIO_PUBLIC_URL=http://localhost:9000
# Production (Cloudflare tunnel):
MINIO_PUBLIC_URL=https://photos.zacharyjcollins.com

# ------------------------------------------------------------
# Cloudflare Tunnel
# Zero Trust → Tunnels → atlas-nuc → token
# The token is the long string after "--token" in the install command.
# ------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=

# ------------------------------------------------------------
# Frontend — API base URL
# Local dev:    http://localhost:8010
# Production:   https://api.zacharyjcollins.com
# This is read at build time by Next.js (NEXT_PUBLIC_ prefix).
# ------------------------------------------------------------
NEXT_PUBLIC_API_BASE=https://api.zacharyjcollins.com

# ------------------------------------------------------------
# Protomaps (map tiles)
# Free API key: https://app.protomaps.com
# Used by the MapLibre map for base tiles + country boundaries.
# ------------------------------------------------------------
NEXT_PUBLIC_PROTOMAPS_KEY=

# ------------------------------------------------------------
# Anthropic (AI destination recommendations)
# https://console.anthropic.com → API Keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# AviationStack (optional — flight auto-enrichment)
# https://aviationstack.com → Dashboard → API Access Key
# Leave blank to disable flight lookup (manual entry still works).
# ------------------------------------------------------------
AVIATIONSTACK_API_KEY=

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
APP_ENV=production
